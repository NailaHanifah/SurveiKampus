<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@drawable/logo_kampus"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Galeri Fasilitas &amp; Survei Kampus"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="#1A237E"
            android:layout_marginBottom="24dp"/>

        <TextView android:text="1. Fakultas Teknologi Informasi (TI) UNISKA" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#0D47A1"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="16dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/kelas_ti"/></androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/fasilitas_ti"/></androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView android:text="2. Fakultas Ilmu Sosial &amp; Ilmu Politik (FISIP)" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#0D47A1"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="16dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/kelas_fisip"/></androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/fasilitas_fisip"/></androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView android:text="3. Fakultas Ekonomi &amp; Bisnis (FEB)" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#0D47A1"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="16dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/kelas_feb"/></androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/fasilitas_feb"/></androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView android:text="4. Fakultas Hukum" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#0D47A1"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="16dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/kelas_hukum"/></androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/fasilitas_hukum"/></androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView android:text="5. Fakultas Keguruan &amp; Ilmu Pendidikan (FKIP)" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#0D47A1"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="24dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/kelas_fkip"/></androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp" app:cardCornerRadius="8dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/fasilitas_fkip"/></androidx.cardview.widget.CardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLihatHasil"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="LIHAT HASIL INTERVIEW"
            android:textColor="#FFFFFF"
            app:backgroundTint="@null"
            android:background="@drawable/btn_selector"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>
</ScrollView>